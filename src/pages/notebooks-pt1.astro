---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
---
<BaseLayout title="Cadernos Parte 1 | Pedro Henrique" bodyClass="selection:bg-primary/20 selection:text-primary">
  <Navigation activePage="notebooks-pt1" />
  <main class="relative pt-32 pb-24 overflow-hidden">
    <!-- Background Organic Elements -->
    <div class="organic-shape top-20 -left-20 w-96 h-96 bg-primary rounded-full" style="filter:blur(80px);opacity:0.15;"></div>
    <div class="organic-shape bottom-20 -right-20 w-[30rem] h-[30rem] bg-[#2d5a27] rounded-full" style="filter:blur(80px);opacity:0.15;"></div>
    <div class="max-w-screen-2xl mx-auto px-8">
      <!-- Hero Header -->
      <header class="mb-20 md:mb-32">
        <span class="inline-block py-2 px-6 rounded-full bg-primary-container/10 text-primary font-label text-sm uppercase tracking-widest mb-6">Volume 01</span>
        <h1 class="font-headline text-6xl md:text-8xl font-extrabold tracking-tighter mb-8 leading-[0.9]">
          Cadernos <br /> <span class="text-primary">Parte 1</span>
        </h1>
        <p class="max-w-2xl text-xl md:text-2xl text-on-surface-variant font-light leading-relaxed">
          Projeto gráfico desenvolvido a partir da combinação entre texturas orgânicas,
          composição minimalista e elementos botânicos. A proposta foi transformar um objeto cotidiano em uma peça
          visual mais expressiva, explorando contraste, materialidade e equilíbrio entre simplicidade e detalhe
        </p>
      </header>
      <!-- Editorial Bento Layout -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-12 items-start">
        <!-- Left Content -->
        <div class="md:col-span-5 space-y-12">
          <div class="bg-[#e8f2e7] rounded-lg p-12 relative overflow-hidden group">
            <div class="absolute -top-10 -right-10 w-40 h-40 border-2 border-[#2d5a27]/10 rounded-full"></div>
            <h2 class="font-headline text-3xl font-bold text-[#2d5a27] mb-6">A Estética</h2>
            <p class="text-[#2d5a27]/80 leading-relaxed mb-8">
              Nesta primeira fase, focamos na harmonização entre o papel texturizado e padrões botânicos simplificados.
              O objetivo é criar uma conexão imediata entre o usuário e o ato de escrever.
            </p>
            <div class="space-y-4">
              <div class="flex items-center gap-4">
                <span class="w-12 h-[1px] bg-[#2d5a27]/30"></span>
                <span class="text-sm font-label uppercase tracking-widest text-[#2d5a27]"></span>
              </div>
              <div class="flex items-center gap-4">
                <span class="w-12 h-[1px] bg-[#2d5a27]/30"></span>
                <span class="text-sm font-label uppercase tracking-widest text-[#2d5a27]"></span>
              </div>
            </div>
          </div>
          <div class="editorial-image-mask aspect-[5/4] bg-surface-container-low shadow-lg">
            <img alt="Mockup de notebook"
              class="w-full h-full object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-700"
              src="/assets/19.jpg" />
          </div>
        </div>
        <!-- Right Content -->
        <div class="md:col-span-7 space-y-12 md:mt-24">
          <div class="editorial-image-mask aspect-[5/4] bg-surface-container shadow-2xl relative">
            <img alt="Layout editorial" class="w-full h-full object-cover" src="/assets/20.jpg" />
            <div class="absolute bottom-6 right-6 bg-white/90 backdrop-blur px-4 py-2 rounded-full text-xs font-label text-primary shadow-sm uppercase tracking-tighter">
              Coleção Primária
            </div>
          </div>
          <a href="/notebooks-pt2"
            class="group block mt-12 border-t border-outline-variant/40 pt-8 hover:border-primary/50 transition-colors duration-500">
            <span class="font-label text-xs uppercase tracking-[0.3em] text-on-surface-variant/60 mb-3 block">Próximo volume</span>
            <div class="flex items-center justify-between gap-4">
              <span class="font-headline text-2xl md:text-3xl font-bold tracking-tight text-on-background group-hover:text-primary transition-colors duration-300">Cadernos Parte 2</span>
              <span class="material-symbols-outlined text-primary text-3xl translate-x-0 group-hover:translate-x-2 transition-transform duration-300">arrow_forward</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
