---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
---
<BaseLayout title="Pedro Henrique | Designer Gráfico">
  <Navigation activePage="home" />
  <main class="relative min-h-screen pt-32 flex items-center overflow-hidden">
    <!-- Organic Background Elements -->
    <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] rounded-full border border-primary/20 pointer-events-none"></div>
    <div class="absolute bottom-[10%] left-[-10%] w-[450px] h-[450px] rounded-full bg-primary/5 pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full border border-primary/5 pointer-events-none"></div>
    <div class="container mx-auto px-8 relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-end">
        <div class="md:col-span-5 mb-12 md:mb-0">
          <div class="space-y-6">
            <p class="font-label text-primary uppercase tracking-[0.3em] font-bold text-sm">Designer Gráfico</p>
            <h1 class="font-headline text-4xl md:text-5xl lg:text-7xl font-bold text-on-surface tracking-tighter leading-none">
              Pedro
              Henrique</h1>
            <p class="font-body text-lg text-on-surface-variant max-w-md leading-relaxed mt-4">
              Designer gráfico com foco em peças digitais, identidade visual e ilustração. Desenvolvo soluções visuais
              que equilibram clareza, consistência e personalidade para comunicação de marcas e projetos.
            </p>
            <div class="flex flex-wrap gap-4 pt-4">
              <a class="px-8 py-4 bg-gradient-to-br from-primary to-primary-container text-white font-bold rounded-full shadow-lg hover:shadow-primary/20 transition-all duration-300 active:scale-95 inline-block text-center"
                href="#featured-works">
                Ver Trabalhos Selecionados
              </a>
              <a class="px-8 py-4 border border-outline-variant/30 text-primary font-bold rounded-full hover:bg-primary/5 transition-all duration-300 inline-block text-center"
                href="/about">
                Sobre Mim
              </a>
            </div>
          </div>
        </div>
        <div class="hidden md:block md:col-span-7 relative h-full min-h-[420px]"></div>
      </div>
    </div>
  </main>
  <!-- Bento Grid Featured Work Section -->
  <section class="py-24 bg-surface-container-low/50" id="featured-works">
    <div class="container mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <a class="md:col-span-2 md:row-span-2 group relative block rounded-lg overflow-hidden aspect-[4/5] md:aspect-auto"
          href="/illustration">
          <img alt="Daredevil comic art illustration piece"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            src="/assets/WhatsApp Image 2026-01-13 at 11.22.48.jpg" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 p-8 flex flex-col justify-end">
            <span class="text-white/60 text-xs font-label uppercase tracking-widest mb-2">Ilustração & Arte em Quadrinhos</span>
            <h3 class="text-white text-3xl font-headline font-bold">A Antologia de Quadrinhos</h3>
          </div>
          <div class="absolute top-8 right-8 w-12 h-12 bg-white rounded-full flex items-center justify-center text-primary shadow-xl opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
            <span class="material-symbols-outlined" translate="no">arrow_outward</span>
          </div>
        </a>
        <a class="md:col-span-2 group relative block rounded-lg overflow-hidden h-[300px]" href="/notebooks-pt1">
          <img alt="Editorial layout notebooks collection"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            src="/assets/19.jpg" />
          <div class="absolute inset-0 bg-on-background/10 backdrop-blur-[2px]"></div>
          <div class="absolute inset-0 p-8 flex flex-col justify-between">
            <h3 class="text-white text-2xl font-headline font-bold">Layouts Editoriais & Cadernos</h3>
            <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-primary self-end shadow-xl hover:scale-110 duration-300 transform group-hover:rotate-45">
              <span class="material-symbols-outlined" translate="no">arrow_outward</span>
            </div>
          </div>
        </a>
        <a class="md:col-span-1 group relative block rounded-lg overflow-hidden h-[300px]" href="/banners">
          <img alt="Sports and Marketing digital banners"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            src="/assets/Times_PEDRO.jpg" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 p-8 flex flex-col justify-end">
            <span class="text-white/60 text-xs font-label uppercase tracking-widest mb-2">Marketing</span>
            <h3 class="text-white text-xl font-headline font-bold">Mídias Sociais & Faixas</h3>
          </div>
        </a>
        <div class="md:col-span-1 group relative rounded-lg overflow-hidden h-[300px] bg-primary-container p-8 flex flex-col justify-center items-center text-center">
          <a class="font-label text-sm uppercase tracking-widest font-bold text-on-primary-container underline decoration-2 underline-offset-4"
            href="/contact">Entre em contato</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
